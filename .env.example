# ── Polymarket ────────────────────────────────────────────────────────────────
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
POLYMARKET_PROXY_ADDRESS=0xYOUR_PROXY_ADDRESS_HERE
# 1 = email/Magic login, 2 = MetaMask/browser wallet
POLYMARKET_SIGNATURE_TYPE=1

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Risk parameters ───────────────────────────────────────────────────────────
# Total USDC allocated to the bot
BANKROLL=100
# 0.25 = quarter-Kelly (recommended starting point)
KELLY_FRACTION=0.25
# Hard cap per single trade in USDC
MAX_BET_USDC=10
# Kill-switch threshold — halt if daily loss exceeds this fraction of bankroll
MAX_DAILY_LOSS_PCT=0.05
MAX_OPEN_POSITIONS=20
# Minimum Claude confidence required to trade: low | medium | high
MIN_CONFIDENCE=medium

# ── Strategy ──────────────────────────────────────────────────────────────────
# Set to false only when ready to go live
DRY_RUN=true
# only markets resolving within 2 days
HORIZON_HOURS=48
# Only fetch markets resolving within at least this many hours
MIN_HOURS_TO_RESOLUTION=2
# How often to scan for opportunities (seconds)
SCAN_INTERVAL_SECONDS=60
# Max markets fetched per cycle
SCAN_LIMIT=50
# Minimum 24h market volume in USDC
VOLUME_MIN=10000
# Minimum market liquidity in USDC
LIQUIDITY_MIN=2000
# Optional: Polymarket tag ID to focus on (leave empty for all)
TAG_ID=
# true = resting limit orders, false = immediate market orders
USE_LIMIT_ORDERS=true
# Seconds to wait between consecutive order placements
TRADE_DELAY_SEC=2
# Let Claude search for news context before analysing each market
USE_WEB_SEARCH=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=/var/log/polybot/bot.log
# Print status summary every N cycles
HEARTBEAT_EVERY_N_CYCLES=5
